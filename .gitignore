# Dependencies
node_modules/
*/node_modules/

# Build outputs
.next/
dist/
build/
out/

# Environment files (keep secrets safe)
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Large media files (keep these separate)
*.mp4
*.mp3
*.wav
*.avi
*.mov

# Temporary files
*.tmp
*.temp
cache/

# Package locks (keep package.json, ignore locks)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Test coverage
coverage/
.nyc_output/

# Large archives (keep these separate)
*.tar.gz
*.zip
*.rar

# Binary files
*.exe
*.dll
*.so
*.bin
